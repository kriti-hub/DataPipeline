# =============================================================================
# WellNow Staffing Analytics — Environment Variables
# =============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to source control.
# =============================================================================

# --- GCP Configuration ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_STAGING_BUCKET=your-staging-bucket
GCS_DASHBOARD_BUCKET=your-dashboard-bucket

# --- BigQuery ---
BQ_DATASET_ID=people_analytics
BQ_LOCATION=US

# --- Simulated HRIS API ---
HRIS_API_URL=http://localhost:8000
HRIS_API_KEY=your-api-key-here
HRIS_API_PORT=8000

# --- ETL Pipeline ---
PIPELINE_RUN_MODE=full
PIPELINE_LOOKBACK_DAYS=7
PIPELINE_LOG_LEVEL=INFO

# --- Cloud Run (API Deployment) ---
CLOUD_RUN_SERVICE_NAME=wellnow-hris-api
CLOUD_RUN_MAX_INSTANCES=1

# --- Cloud Functions (ETL Deployment) ---
CLOUD_FUNCTION_NAME=wellnow-etl-pipeline
CLOUD_FUNCTION_TIMEOUT=540
CLOUD_FUNCTION_MEMORY=512MB

# --- Cloud Scheduler ---
SCHEDULER_CRON="0 6 * * *"
SCHEDULER_TIMEZONE=UTC

# --- Dashboard ---
VITE_DATA_BASE_URL=/data
