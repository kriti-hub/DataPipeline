# Secrets — NEVER commit
.env
.env.local
.env.production
*.key
*.pem
service-account*.json
credentials*.json

# Data files — NEVER commit raw data
*.csv
*.json.gz
data/raw/
data/staging/
data/local_output/

# Keep dashboard data (small pre-computed JSON)
!src/dashboard/public/data/*.json

